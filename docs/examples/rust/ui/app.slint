// Example app window for the Rust host language integration example.
// Import paths are relative to this file's location in the repository.

import { Button, VerticalBox } from "std-widgets.slint";
import { ToastHost } from "../../../../ui/toast-host.slint";
import { ToastKind, ToastAnchor } from "../../../../ui/toast-types.slint";

export component AppWindow inherits Window {
    title: "Toast — Rust Example";
    width: 480px;
    height: 320px;

    // Expose toast control to the Rust host via public functions.
    // Rust generates: ui.invoke_show_toast(...) and ui.invoke_hide_toast()
    public function show-toast(text: string, kind: ToastKind) {
        toast-host.show(text, kind);
    }

    public function hide-toast() {
        toast-host.hide();
    }

    // Callbacks fired by the toast — Rust connects via ui.on_toast_closed(...)
    callback toast-closed();
    callback toast-action();

    VerticalBox {
        alignment: center;
        spacing: 12px;
        padding: 24px;

        Button {
            text: "Info";
            clicked => {
                toast-host.show("This is an info message.", ToastKind.Info);
            }
        }

        Button {
            text: "Success";
            clicked => {
                toast-host.show("Operation completed successfully.", ToastKind.Success);
            }
        }

        Button {
            text: "Warning";
            clicked => {
                toast-host.show("Disk space is running low.", ToastKind.Warning);
            }
        }

        Button {
            text: "Error";
            clicked => {
                toast-host.show("Connection failed.", ToastKind.Error);
            }
        }
    }

    // ToastHost MUST be the last direct child of the Window.
    toast-host := ToastHost {
        anchor: ToastAnchor.BottomRight;
        toast-closed => {
            root.toast-closed();
        }
        toast-action => {
            root.toast-action();
        }
    }
}
