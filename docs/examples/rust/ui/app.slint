// Example app window for the Rust host language integration example.
// Import paths are relative to this file's location in the repository.
//
// With ToastGlobals, Rust drives toast state via ui.global::<ToastGlobals>()
// directly — no wrapper public functions or forwarding callbacks needed on AppWindow.

import { Button, VerticalBox } from "std-widgets.slint";
import { ToastHost } from "../../../../ui/toast_host.slint";
import { ToastKind, ToastAnchor } from "../../../../ui/toast_types.slint";
export { ToastGlobals } from "../../../../ui/toast_globals.slint";

export component AppWindow inherits Window {
    title: "Toast — Rust Example";
    width: 480px;
    height: 320px;

    VerticalBox {
        alignment: center;
        spacing: 12px;
        padding: 24px;

        // Slint-to-Slint: buttons call toast-host.show() directly — no Rust involved.
        Button {
            text: "Info";
            clicked => { toast-host.show("This is an info message.", ToastKind.Info); }
        }

        Button {
            text: "Success";
            clicked => { toast-host.show("Operation completed successfully.", ToastKind.Success); }
        }

        Button {
            text: "Warning";
            clicked => { toast-host.show("Disk space is running low.", ToastKind.Warning); }
        }

        Button {
            text: "Error";
            clicked => { toast-host.show("Connection failed.", ToastKind.Error); }
        }
    }

    // ToastHost MUST be the last direct child of the Window.
    toast-host := ToastHost {
        anchor: ToastAnchor.BottomRight;
    }
}
